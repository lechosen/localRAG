LLM_PROVIDER=ollama              # ollama | anthropic | openai | deepseek
LLM_MODEL=qwen2.5:1.5b          # ollama: qwen2.5:1.5b, gemma3:4b, llama3.2:3b
                                 # anthropic: claude-sonnet-4-6
                                 # openai: gpt-4o
                                 # deepseek: deepseek-chat

EMBED_PROVIDER=ollama            # ollama | openai
EMBED_MODEL=nomic-embed-text     # ollama: nomic-embed-text, mxbai-embed-large
                                 # openai: text-embedding-3-small
                                 # NOTE: changing EMBED_MODEL requires re-ingesting all documents
                                 #       use a matching CHROMA_DIR to keep collections isolated

CHROMA_DIR=./chroma_db           # tip: use ./chroma_db/nomic-embed-text to isolate by model

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
